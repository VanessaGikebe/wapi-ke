# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# PostgreSQL connection string (SQLAlchemy / psycopg v3 format)
DATABASE_URL=postgresql+psycopg://wapike:wapike@localhost:5432/wapike

# Secret used to sign JWT access/refresh tokens. Generate a long random value.
JWT_SECRET=change-me-to-a-long-random-secret

# Anthropic Claude API key for the server-side AI assistant router.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT / auth (optional — defaults shown). Set COOKIE_SECURE=true in production.
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# COOKIE_SECURE=false
