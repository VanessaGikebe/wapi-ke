# Copy this file to `.env` and fill in real values. `.env` is git-ignored.

# PostgreSQL connection string (SQLAlchemy / psycopg v3 format)
DATABASE_URL=postgresql+psycopg://wapike:wapike@localhost:5432/wapike

# Secret used to sign JWT access/refresh tokens. Generate a long random value.
JWT_SECRET=change-me-to-a-long-random-secret

# Anthropic Claude API key for the server-side AI assistant router.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API key (Google AI Studio) — powers the AI assistant.
GEMINI_API_KEY=

# Google Sign-In: OAuth 2.0 "Web application" client ID from
# https://console.cloud.google.com/apis/credentials . Must MATCH the frontend's
# NEXT_PUBLIC_GOOGLE_CLIENT_ID. Leave blank to disable Google sign-in (the
# POST /auth/google endpoint then returns 503).
GOOGLE_CLIENT_ID=

# Supabase auth bridge — when set, protected routes accept Supabase JWTs
# (verified against the project JWKS) as well as legacy app tokens.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json
# Supabase service (secret) key — SERVER-SIDE ONLY. Used to create auth
# accounts on approval and mint activation magic links. Never expose to the
# browser.
SUPABASE_SERVICE_KEY=

# Where activation magic links point the browser (the frontend origin).
FRONTEND_URL=http://localhost:3000

# Business onboarding. "manual" = admins review uploaded documents by hand.
# Swap for "ecitizen_brs" once that provider is implemented.
VERIFICATION_PROVIDER=manual

# One-time magic-link / admin-invitation lifetime (hours).
# MAGIC_LINK_EXPIRY_HOURS=24
# ADMIN_INVITE_EXPIRY_HOURS=24

# Transactional email (Resend) for production magic-link delivery. Leave blank
# in development to use Supabase Auth's built-in magic-link emails.
RESEND_API_KEY=
EMAIL_FROM=WapiKE <no-reply@wapike.co.ke>

# JWT / auth (optional — defaults shown). Set COOKIE_SECURE=true in production.
# JWT_ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=7
# COOKIE_SECURE=false
