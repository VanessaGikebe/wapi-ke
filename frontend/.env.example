# Copy this file to `.env.local` (git-ignored) and fill in values.

# Base URL of the backend API. Defaults to http://localhost:8000/api/v1.
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Google Sign-In — OAuth 2.0 "Web application" client ID from
# https://console.cloud.google.com/apis/credentials
# Must MATCH the backend's GOOGLE_CLIENT_ID.
# In the Google console, add these to the client's "Authorized JavaScript origins":
#   http://localhost:3000   (and your production origin)
# Leave blank to show the Google button disabled (Apple stays a placeholder).
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
