# Copy to `.env.local` (git-ignored) and fill in real values.

# --- Supabase (browser-safe) ---
# Project URL and the PUBLISHABLE (anon) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- Supabase (server only — NEVER prefix with NEXT_PUBLIC) ---
# The SECRET / service-role key. Used only in server code (lib/supabase/admin.ts).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx
# JWKS endpoint for verifying Supabase JWTs (FastAPI bridge).
SUPABASE_JWKS_URL=https://YOUR-PROJECT.supabase.co/auth/v1/.well-known/jwks.json

# --- App ---
# FastAPI base URL (data endpoints, bridged to Supabase auth).
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
# This app's public origin (OAuth + email redirect target).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
